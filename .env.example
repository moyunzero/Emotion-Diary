# Groq API Key（应用内 AI 功能读取；可选，无 Key 时使用默认文案）
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key_here

# Supabase（云端同步；可选）
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 以下为可选预留：当前应用代码未引用 EXPO_PUBLIC_HF_TOKEN（无 Hugging Face 调用时可不配置）
# Hugging Face API Token (optional; not used by current app code)
EXPO_PUBLIC_HF_TOKEN=your_huggingface_token_here

# 注意事项：
# 1. 复制此文件为 .env 并填入真实的API密钥
# 2. 不要将包含真实密钥的 .env 文件提交到版本控制
# 3. 生产环境应使用 EAS Secrets 管理这些密钥
# 4. 所有以 EXPO_PUBLIC_ 开头的变量会被打包到客户端代码中
