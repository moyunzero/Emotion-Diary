{
  "expo": {
    "name": "心晴MO",
    "slug": "emotion-diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "emotiondiary",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moyunzero.emotiondiary",
      "minimumOsVersion": "15.1",
      "splash": {
        "image": "./assets/images/app-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "焚语需要使用 Face ID 以保护你的情绪日记与隐私数据",
        "NSMicrophoneUsageDescription": "焚语需要访问麦克风以录制语音日记（仅在你使用该功能时）",
        "NSPhotoLibraryUsageDescription": "焚语仅在你保存情绪回顾图时访问相册以完成写入。",
        "NSPhotoLibraryAddUsageDescription": "焚语需要将你的情绪回顾图保存到相册，仅在您点击保存时写入。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.moyunzero.emotiondiary",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"],
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "焚语仅在你保存情绪回顾图时访问相册以完成写入。",
          "savePhotosPermission": "焚语需要将你的情绪回顾图保存到相册，仅在您点击保存时写入。",
          "granularPermissions": ["photo"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "267ba426-3cba-4e7e-bc99-83bb98c57000"
      }
    }
  }
}
